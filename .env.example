# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=llama3.2

# ── Flask ─────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=1

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no extra config needed):
DB_TYPE=sqlite
DATABASE_URL=chat.db

# PostgreSQL (uncomment and fill in when ready to migrate):
# DB_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/ollama_chat
